{
  "name": "eval-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source evaluation framework for research agents — measuring collaborative task performance on real human workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/akaieuan/eval-kit.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "vite": "^6.4.2"
    }
  }
}
