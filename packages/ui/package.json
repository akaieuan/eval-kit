{
  "name": "@eval-kit/ui",
  "version": "0.3.1",
  "description": "React components and pages for scoring, reviewing, and diffing eval runs. Tailwind + Radix.",
  "license": "MIT",
  "author": "Ieuan King",
  "homepage": "https://github.com/akaieuan/eval-kit#readme",
  "bugs": "https://github.com/akaieuan/eval-kit/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/akaieuan/eval-kit.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "eval",
    "llm",
    "agent",
    "evaluation",
    "hitl",
    "react",
    "tailwind"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles/tokens.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no ui tests yet'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@eval-kit/core": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "^0.469.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^19 || ^18",
    "react-dom": "^19 || ^18"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
